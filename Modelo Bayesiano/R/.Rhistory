forecast_arima_prices <- function(fit, original_series, d = 1, horizon = 10) {
require(xts)
# Diferenciar serie
serie_diff <- diff(original_series, differences = d)[-1]
last_value <- tail(original_series, 1)
# Ajustar modelo
samples <- extract(fit)
# Calcular pronósticos
forecasts <- apply(samples$y_hat, 2, function(x) {
c(
mean = mean(x),
lower = quantile(x, 0.05),
upper = quantile(x, 0.95)
)
})
# Crear serie temporal
forecast_dates <- seq(end(original_series), by = "day", length.out = horizon + 1)[-1]
xts(
t(forecasts),
order.by = forecast_dates
)
}
library(xts)
library(readr)
source("Pronostico.R")
# Cargar y preparar datos
data <- read_csv("C:\Users\dani_\OneDrive\Escritorio\Prueba ST\NU_Historical_Data.csv")[-1,]
library(xts)
library(readr)
source("Pronostico.R")
# Cargar y preparar datos
data <- read_csv("C:/Users/dani_/OneDrive/Escritorio/Prueba ST/NU_Historical_Data.csv")[-1,]
data$Date <- as.Date(data$Date, format = "%m/%d/%Y")
data$Close <- as.numeric(data$Close)
serie <- xts(data$Close, order.by = data$Date)["2021-12-09/2024-02-26"]
# Paso 1: Diferenciar serie
d <- 1
# Extrae la serie diferenciada y asegúrate de que sea un vector unidimensional
serie_diff <- diff(serie, differences = d)[-1]
serie_diff_vector <- as.numeric(coredata(serie_diff))
# Genera el modelo Stan
model_info <- generate_arima_price_stan(serie_diff)
# Ajusta el modelo con los datos correctos (vector unidimensional)
fit <- stan(
file = model_info$stan_file,
data = list(
N = length(serie_diff_vector),
y = serie_diff_vector,  # Usa el vector numérico en lugar de coredata directamente
H = 10,
last_value = as.numeric(tail(serie, 1))  # Convierte a numérico simple
),
iter = 2000,
chains = 4
)
library(rstan)
# Ajusta el modelo con los datos correctos (vector unidimensional)
fit <- stan(
file = model_info$stan_file,
data = list(
N = length(serie_diff_vector),
y = serie_diff_vector,  # Usa el vector numérico en lugar de coredata directamente
H = 10,
last_value = as.numeric(tail(serie, 1))  # Convierte a numérico simple
),
iter = 2000,
chains = 4
)
# Paso 4: Pronosticar
pronosticos <- forecast_arima_prices(fit, serie, d = 1)
print(pronosticos)
